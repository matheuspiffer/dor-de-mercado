generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Response {
  id        String   @id @default(cuid())
  name      String
  email     String
  role      String
  industry  String
  painPoint String   @db.Text
  frequency String
  currentSolution String @db.Text
  willingToPay   String
  additionalInfo String? @db.Text
  createdAt DateTime @default(now())

  @@map("responses")
}
